{
  "name": "swcad-js",
  "version": "0.10.3-alpha.1",
  "description": "Salvador Workshop's JSCAD utilities and toolkit",
  "workspaces": [
    "packages/*"
  ],
  "main": "src/index.js",
  "scripts": {
    "docs:builders": "cd packages/swcad-js-builders && npm run docs",
    "docs:core": "cd packages/swcad-js-core && npm run docs",
    "docs:families": "cd packages/swcad-js-families && npm run docs",
    "docs:std-specs": "cd packages/swcad-js-std-specs && npm run docs",
    "docs:ui": "cd packages/swcad-js-ui && npm run docs",
    "docs": "jsdoc packages -r -d docs -c jsdoc.json --readme readme.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salvador-workshop/swcad-js.git"
  },
  "keywords": [
    "openjscad",
    "jscad",
    "code-cad",
    "codecad"
  ],
  "author": "R. J. Salvador <salvador.workshop@gmail.com>",
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "jsdoc": "^4.0.4"
  }
}